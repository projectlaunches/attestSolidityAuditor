# The preferred provider uses `Sign in with ChatGPT` through Codex app-server.
# Override this only when Codex is installed somewhere unusual.
# CODEX_BIN=/absolute/path/to/codex

SOLTESTING_HOST=127.0.0.1
SOLTESTING_PORT=8787
SOLTESTING_MODEL=gpt-5.6-luna

# `npm run launch` sets this automatically. Normal start/dev never open a browser.
# ATTEST_OPEN_BROWSER=1
# ATTEST_DATA_DIR=/absolute/private/runtime/path
