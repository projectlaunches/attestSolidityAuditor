{
  "name": "attest",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local, evidence-backed Solidity audit workbench",
  "scripts": {
    "dev": "node --watch src/server/index.js",
    "start": "node src/server/index.js",
    "launch": "ATTEST_OPEN_BROWSER=1 node src/server/index.js",
    "test": "node --test tests/*.test.js",
    "check": "node scripts/check-syntax.mjs && node --test tests/*.test.js",
    "deps:audit": "npm audit --audit-level=high",
    "tools:install-aderyn": "node scripts/install-aderyn.mjs",
    "codex:version": "codex --version"
  },
  "optionalDependencies": {
    "@openai/codex": "0.145.0"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "solhint-community": "4.0.1"
  }
}
